NODE_ENV=development
PORT=5050
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5174

# ========== DATABASE (AWS RDS PostgreSQL) ==========
DB_HOST=your-rds-endpoint.ap-south-1.rds.amazonaws.com
DB_USER=postgres
DB_PASSWORD=your-password
DB_NAME=postgres
DB_PORT=5432
DB_SSL=require

# You can also use one connection string instead of the DB_* fields:
# DATABASE_URL=postgresql://postgres:your-password@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/postgres?sslmode=require&uselibpqcompat=true
